{
  "realm": "mam",
  "enabled": true,
  "displayName": "MAM",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginTheme": "mam",
  "clients": [
    {
      "clientId": "mam-web",
      "name": "mam-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "__CLIENT_SECRET__",
      "redirectUris": [
        "http://__PUBLIC_HOST__:3000/oauth2/callback"
      ],
      "webOrigins": [
        "http://__PUBLIC_HOST__:3000"
      ],
      "baseUrl": "http://__PUBLIC_HOST__:3000",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "metmam-mobile",
      "name": "metmam-mobile",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "com.example.metmam:/oauth2redirect"
      ],
      "webOrigins": [
        "+"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "mam-admin-access"
      },
      {
        "name": "mam-asset-delete"
      },
      {
        "name": "mam-office-edit"
      },
      {
        "name": "mam-metadata-edit"
      },
      {
        "name": "mam-pdf-advanced"
      },
      {
        "name": "admin-access"
      },
      {
        "name": "asset-delete"
      }
    ]
  },
  "users": [
    {
      "username": "__MAM_ADMIN_USER__",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "__MAM_ADMIN_PASSWORD__",
          "temporary": false
        }
      ],
      "realmRoles": [
        "mam-admin-access",
        "mam-asset-delete",
        "mam-office-edit",
        "mam-metadata-edit",
        "mam-pdf-advanced",
        "admin-access",
        "asset-delete"
      ]
    },
    {
      "username": "__MAM_USER__",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "__MAM_USER_PASSWORD__",
          "temporary": false
        }
      ]
    }
  ]
}
