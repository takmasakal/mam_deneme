# Keycloak admin account
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Keycloak database
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_DB_NAME=keycloak

# OAuth2 Proxy / OIDC
OAUTH2_PROXY_OIDC_ISSUER_URL=http://keycloak:8080/realms/mam
OAUTH2_PROXY_CLIENT_ID=mam-web
OAUTH2_PROXY_CLIENT_SECRET=change-me
# Base64-encoded 32-byte random string
OAUTH2_PROXY_COOKIE_SECRET=change-me
OAUTH2_PROXY_REDIRECT_URL=http://localhost:3000/oauth2/callback

# Office editor provider:
# none      = lightweight native workflow, no web Office editor container
# onlyoffice = enable ONLYOFFICE web editor
# libreoffice = offline read-only PDF preview via LibreOffice headless
OFFICE_EDITOR_PROVIDER=onlyoffice

# Set true only when OFFICE_EDITOR_PROVIDER=libreoffice or when you want
# LibreOffice tools installed inside the app image. Default keeps image smaller.
INSTALL_LIBREOFFICE=false
